       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2020-03-30T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 6 ;
     fhir:CodeSystem.concept.code [ fhir:value "SI04" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Exercice infirmier en pratique avancée santé mentale (SI)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Exercice infirmier autorisé en pratique avancée en santé mentale. La notion de spécialité ordinale a été introduite sachant qu'il est nécessaire de distinguer l'exercice d'IPA de celui d'infirmier et que le diplôme ne suffit  pas pour autoriser l'exercice d'IPA. Il faut 3 ans de pratique infirmière pour pouvoir exercer comme IPA; mais le cursus d'IPA peut être accessible dans le prolongement du DE d'infirmier.  Un IPA peut exercer des activités d'IPA dans plusieurs spécialités, mais aussi, plus fréquemment cumuler des activités d'IPA et d'activité d'infirmier polyvalent du niveau du DE Infirmier." ] ;
