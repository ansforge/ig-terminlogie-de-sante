     ]
  ], [
     fhir:index 285 ;
     fhir:CodeSystem.concept.code [ fhir:value "286" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Unité hospitalière de Soins Intensifs Néonatals (USIN)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Une unité de soins intensifs néonatals (USIN), prend en charge, sur décision médicale, des nouveau-nés présentant une ou plusieurs pathologies aiguës. Cette unité prend en charge en soins intensifs les nouveau-nés présentant une ou plusieurs pathologies aiguës ou dans les suites d’une réanimation néonatale. Ce secteur peut être organisé au sein de l'unité de néonatologie" ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
         a sct:900000000000013009 ;
         fhir:Coding.system [ fhir:value "http://snomed.info/sct" ] ;
         fhir:Coding.code [ fhir:value "900000000000013009" ]
       ] ;
       fhir:CodeSystem.concept.designation.value [ fhir:value "USIN" ]
     ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-12-22T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2026-03-30T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 286 ;
     fhir:CodeSystem.concept.code [ fhir:value "287" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Unité hospitalière de réanimation néonatale" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "L'unité de réanimation néonatale assure tous les jours de l'année, vingt-quatre heures sur vingt-quatre, la surveillance et les soins spécialisés aux nouveau-nés. Cette unité est associée à un secteur de soins intensifs de néonatologie sur le même site. La réanimation néonatale s'exerce dans des installations autorisées à cet effet. Elle ne peut être pratiquée que si l'établissement de santé comprend sur le même site une unité de néonatologie autorisée dont une partie des installations est affectée aux soins intensifs de néonatologie. L’unité de réanimation néonatale prend en charge sur décision médicale les nouveau-nés, souvent prématurés, présentant des détresses graves ou des risques vitaux." ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
         a sct:900000000000013009 ;
