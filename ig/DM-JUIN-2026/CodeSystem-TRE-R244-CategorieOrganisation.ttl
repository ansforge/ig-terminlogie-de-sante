         fhir:v "active"
       ]
     ] )
  ] [
     fhir:code [ fhir:v "288" ] ;
     fhir:display [ fhir:v "Unité hospitalière « kangourou » ou « koala »" ] ;
     fhir:definition [ fhir:v "Les unités dites « kangourou » (ou « koala » dans certains territoires) sont des unités de néonatalogie qui proposent également la prise en charge de la mère dans la même chambre. Ces unités prennent en charge sur décision médicale les nouveau-nés à risque et ceux dont l’état de santé s’est dégradé après la naissance ainsi que la personne venant d’accoucher." ] ;
     fhir:designation ( [
       fhir:language [ fhir:v "fr-FR" ] ;
