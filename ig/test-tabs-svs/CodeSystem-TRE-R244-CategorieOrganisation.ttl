     ]
  ], [
     fhir:index 277 ;
     fhir:CodeSystem.concept.code [ fhir:value "278" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Unité Hospitalière de Courte Durée (UHCD)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Il s'agit d'une unité rattachée aux urgences qui accueille temporairement des patients nécessitant une surveillance, des examens complémentaires ou des soins avant une décision d’hospitalisation ou de retour à domicile. Elle assure une prise en charge continue, limitée à 24 ou 48 heures." ] ;
