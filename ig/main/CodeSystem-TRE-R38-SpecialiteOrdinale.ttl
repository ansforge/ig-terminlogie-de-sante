     fhir:CodeSystem.concept.code [ fhir:value "SI03" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Exercice infirmier en pratique avancée maladie rénale chronique (SI)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Exercice infirmier autorisé en pratique avancée en maladie rénale. chronique, dialyse et transplantation rénale. La notion de spécialité ordinale a été introduite sachant qu'il est nécessaire de distinguer l'exercice d'IPA de celui d'infirmier et que le diplôme ne suffit  pas pour autoriser l'exercice d'IPA. Il faut 3 ans de pratique infirmière pour pouvoir exercer comme IPA; mais le cursus d'IPA peut être accessible dans le prolongement du DE d'infirmier.  Un IPA peut exercer des activités d'IPA dans plusieurs spécialités, mais aussi, plus fréquemment cumuler des activités d'IPA et d'activité d'infirmier polyvalent du niveau du DE Infirmier." ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
         a sct:900000000000013009 ;
         fhir:Coding.system [ fhir:value "http://snomed.info/sct" ] ;
         fhir:Coding.code [ fhir:value "900000000000013009" ]
       ] ;
       fhir:CodeSystem.concept.designation.value [ fhir:value "IPA maladie rénale" ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
         a sct:900000000000013009 ;
         fhir:Coding.system [ fhir:value "http://snomed.info/sct" ] ;
         fhir:Coding.code [ fhir:value "900000000000013009" ]
       ] ;
       fhir:CodeSystem.concept.designation.value [ fhir:value "Exercice infirmier en pratique avancée maladie rénale chronique, dialyse et transplantation rénale (SI)" ]
     ] ;
