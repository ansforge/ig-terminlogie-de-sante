  ], [
     fhir:index 1419 ;
     fhir:CodeSystem.concept.code [ fhir:value "1420" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Pontage coronarien à coeur battant" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Technique chirurgicale qui consiste à créer un nouveau passage pour le sang afin de contourner les artères coronaires obstruées ou rétrécies, tout en maintenant le coeur en activité pendant l'intervention. Contrairement à la chirurgie traditionnelle, qui utilise une machine coeur-poumon pour faire circuler le sang pendant l'opération, le pontage à coeur battant est réalisé sans arrêter le coeur." ] ;
