     ]
  ], [
     fhir:index 1405 ;
     fhir:CodeSystem.concept.code [ fhir:value "1406" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Hypnose périopératoire" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Technique de prise en charge non médicamenteuse qui utilise l'hypnose (état modifié de conscience induit de manière volontaire) pour améliorer l'expérience et les résultats chirurgicaux chez les patients. Elle est pratiquée avant, pendant et après l'intervention chirurgicale pour réduire l'anxiété, gérer la douleur, minimiser le stress et favoriser la récupération." ] ;
