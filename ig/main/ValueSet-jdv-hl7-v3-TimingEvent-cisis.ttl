  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "extensions" ] ;
     fhir:Narrative.div "<div xml:lang=\"fr-FR\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"fr-FR\"><p class=\"res-header-id\"><b>Narratif généré : EnsembleValeurs jdv-hl7-v3-TimingEvent-cisis</b></p><a name=\"jdv-hl7-v3-TimingEvent-cisis\"> </a><a name=\"hcjdv-hl7-v3-TimingEvent-cisis\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\">version : 10; Dernière mise à jour : 2026-06-22 14:01:19+0200; Langue : fr-FR</p><p style=\"margin-bottom: 0px\">Profil: <a href=\"http://hl7.org/fhir/R4/shareablevalueset.html\">Shareable ValueSet</a></p></div><ul><li>Include ce(s) code(s) tel qu'il(s) est (sont) défini(s) dans <a href=\"http://terminology.hl7.org/7.2.0/CodeSystem-v3-TimingEvent.html\"><code>http://terminology.hl7.org/CodeSystem/v3-TimingEvent</code></a><span title=\"La version est explicitement indiquée comme étant 4.0.0\"> version ?4.0.0</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Affichage</b></td><td><b>Définition</b></td></tr><tr><td><code>AC</code></td><td>Avant le repas</td><td>before meal (from lat. ante cibus)</td></tr><tr><td><code>ACD</code></td><td>Avant le déjeuner</td><td>before lunch (from lat. ante cibus diurnus)</td></tr><tr><td><code>ACM</code></td><td>Avant le petit-déjeuner</td><td>before breakfast (from lat. ante cibus matutinus)</td></tr><tr><td><code>ACV</code></td><td>Avant le dîner</td><td>before dinner (from lat. ante cibus vespertinus)</td></tr><tr><td><code>C</code></td><td>Pendant les repas</td><td>**Description:** meal (from lat. ante cibus)</td></tr><tr><td><code>CD</code></td><td>Pendant le déjeuner</td><td>**Description:** lunch (from lat. cibus diurnus)</td></tr><tr><td><code>CM</code></td><td>Pendant le petit-déjeuner</td><td>**Description:** breakfast (from lat. cibus matutinus)</td></tr><tr><td><code>CV</code></td><td>Pendant le dîner</td><td>**Description:** dinner (from lat. cibus vespertinus)</td></tr><tr><td><code>HS</code></td><td>Au coucher</td><td>**Description:** Prior to beginning a regular period of extended sleep (this would exclude naps). Note that this might occur at different times of day depending on a person's regular sleep schedule.</td></tr><tr><td><code>IC</code></td><td>Entre les repas</td><td>between meals (from lat. inter cibus)</td></tr><tr><td><code>ICD</code></td><td>Entre le déjeuner et le dîner</td><td>between lunch and dinner</td></tr><tr><td><code>ICM</code></td><td>Entre le petit-déjeûner et le déjeûner</td><td>between breakfast and lunch</td></tr><tr><td><code>ICV</code></td><td>Entre le diner et le coucher</td><td>between dinner and the hour of sleep</td></tr><tr><td><code>PC</code></td><td>Après le repas</td><td>after meal (from lat. post cibus)</td></tr><tr><td><code>PCD</code></td><td>Après le déjeuner</td><td>after lunch (from lat. post cibus diurnus)</td></tr><tr><td><code>PCM</code></td><td>Après le petit-déjeuner</td><td>after breakfast (from lat. post cibus matutinus)</td></tr><tr><td><code>PCV</code></td><td>Après le dîner</td><td>after dinner (from lat. post cibus vespertinus)</td></tr><tr><td><code>WAKE</code></td><td>Au réveil</td><td>**Description:** Upon waking up from a regular period of sleep, in order to start regular activities (this would exclude waking up from a nap or temporarily waking up during a period of sleep)<br/><br/>**Usage Notes:** e.g.<br/><br/>Take pulse rate on waking in management of thyrotoxicosis.<br/><br/>Take BP on waking in management of hypertension<br/><br/>Take basal body temperature on waking in establishing date of ovulation</td></tr></table></li></ul></div>"
  ] ;
