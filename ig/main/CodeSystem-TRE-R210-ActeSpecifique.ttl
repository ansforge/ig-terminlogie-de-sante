  ], [
     fhir:index 1150 ;
     fhir:CodeSystem.concept.code [ fhir:value "1151" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Chirurgie carcinologique de l'oesophage ou de la jonction gastro-oesophagienne" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Branche de la chirurgie qui s'intéresse au cancer de l'oesophage dans le but de traiter la tumeur, de réduire la propagation de la maladie et d'améliorer le pronostic du patient. Cette chirurgie peut inclure différentes procédures en fonction du stade et de la localisation du cancer, telles que l'oesophagectomie partielle ou totale, parfois associée à une reconstruction de l'oesophage à l'aide de tissus voisins ou de prothèses." ] ;
