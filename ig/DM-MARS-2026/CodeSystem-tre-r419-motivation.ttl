     fhir:code [ fhir:v "259" ] ;
     fhir:display [ fhir:v "Attrib MPA" ] ;
     fhir:definition [ fhir:v "Après l'évaluation des besoins et des capacités de votre enfant, la CDAPH a reconnu qu'il a besoin de matériel pédagogique adapté pour compenser ses besoins et favoriser sa scolarité et ses apprentissages (article D351-7 du code de l'éducation)." ] ;
