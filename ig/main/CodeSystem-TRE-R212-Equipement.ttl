     fhir:index 172 ;
     fhir:CodeSystem.concept.code [ fhir:value "173" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Polymorphisme mononucléotidique" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Equipement qui permet d'identifier une différence génétique entre individus d’une même population qui se traduit par la variation d’une seule base (nucléotide) dans une séquence d’ADN, l’allèle minoritaire ayant une fréquence d’au moins 1 %. Ce type de variation, appelé aussi SNP (single nucleotide polymorphism), est très courant dans le génome humain et constitue une des principales sources de diversité individuelle. (Description scientifique de la nature et de la fréquence des SNP)" ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
