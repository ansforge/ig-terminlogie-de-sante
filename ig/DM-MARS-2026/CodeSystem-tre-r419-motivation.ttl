     fhir:code [ fhir:v "266" ] ;
     fhir:display [ fhir:v "Attrib PCH1 adulte" ] ;
     fhir:definition [ fhir:v "Après évaluation de votre situation, de votre autonomie et en tenant compte de vos besoins, la CDAPH a reconnu que vous avez des difficultés pour réaliser des activités de la vie quotidienne et que vous avez besoin d'aide pour ces activités. Ces difficultés sont suffisamment importantes pour remplir les critères d'attribution de la PCH. Les critères spécifiques pour l'accès à l'aide humaine sont également remplis (annexe 2-5 et article L.245-4 du code de l'action sociale et des familles)." ] ;
     fhir:property ( [
       fhir:code [ fhir:v "dateValid" ] ;
