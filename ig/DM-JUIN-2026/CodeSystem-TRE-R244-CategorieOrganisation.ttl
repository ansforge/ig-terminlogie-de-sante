         fhir:v "2025-12-22T12:00:00+01:00"^^xsd:dateTime
       ]
     ] [
       fhir:code [ fhir:v "status" ] ;
       fhir:value [
         a fhir:Code ;
         fhir:v "active"
       ]
     ] )
  ] [
     fhir:code [ fhir:v "277" ] ;
     fhir:display [ fhir:v "Equipe de coordination hospitalière de tissus et/ou d’organes" ] ;
     fhir:definition [ fhir:v "Il s'agit d'une équipe hospitalière pluridisciplinaire chargée d’identifier les donneurs potentiels d’organes et de tissus, d’organiser et de coordonner les prélèvements, en garantissant le respect des règles légales, éthiques et de sécurité sanitaire, ainsi que l’accompagnement des proches. Elle assure la liaison entre les services hospitaliers, les équipes de greffe et l’Agence de la biomédecine pour la traçabilité et la qualité du don." ] ;
     fhir:designation ( [
       fhir:language [ fhir:v "fr-FR" ] ;
       fhir:use [
         a sct:900000000000013009 ;
         fhir:system [
