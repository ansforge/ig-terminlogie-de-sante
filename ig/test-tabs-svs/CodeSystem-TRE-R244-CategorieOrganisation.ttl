  ], [
     fhir:index 12 ;
     fhir:CodeSystem.concept.code [ fhir:value "13" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Service d'Accueil Familial Thérapeutique en psychiatrie" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "L’accueil familial thérapeutique est une modalité particulière de prise en charge. Les services d’accueil familial thérapeutique organisent le traitement des personnes de tous âges, souffrant de troubles mentaux susceptibles de retirer un bénéfice d’une prise en charge thérapeutique dans un milieu familial substitutif stable, en vue notamment d’une restauration de leurs capacités relationnelles et d’autonomie." ] ;
     fhir:CodeSystem.concept.designation [
