  ] [
     fhir:code [ fhir:v "A" ] ;
     fhir:display [ fhir:v "Catégorie A, permis moto" ] ;
     fhir:definition [ fhir:v "Il existe trois catégories du permis moto : A1, A2 et A. Ces catégories requièrent différents examens et définissent la taille de la cylindrée autorisée à être conduite." ] ;
     fhir:property ( [
