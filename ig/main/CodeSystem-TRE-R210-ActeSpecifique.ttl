     fhir:CodeSystem.concept.display [ fhir:value "Soin diététique et nutritionnel des personnes en situation de handicap" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Élaboration de stratégies nutritionnelles individualisées prenant en compte les troubles associés, les contraintes motrices, sensorielles ou cognitives." ] ;
