  ], [
     fhir:index 1524 ;
     fhir:CodeSystem.concept.code [ fhir:value "1526" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Soin diététique et nutritionnel pédiatrique pendant et après les traitements oncologiques" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Ensemble des interventions diététiques réalisées auprès d’enfants atteints de cancer, tout au long du parcours de soins, depuis le diagnostic jusqu’à la phase de rémission ou de suivi post-thérapeutique comprenant une évaluation nutritionnelle, l'adaptation des apports nutritionnels pour prévenir la dénutrition ou les excès." ] ;
