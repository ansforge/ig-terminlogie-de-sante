       ]
     ] )
  ] [
     fhir:code [ fhir:v "286" ] ;
     fhir:display [ fhir:v "Unité hospitalière de Soins Intensifs Néonatals (USIN)" ] ;
     fhir:definition [ fhir:v "Une unité de soins intensifs néonatals (USIN), prend en charge, sur décision médicale, des nouveau-nés présentant une ou plusieurs pathologies aiguës. Cette unité prend en charge en soins intensifs les nouveau-nés présentant une ou plusieurs pathologies aiguës ou dans les suites d’une réanimation néonatale. Ce secteur peut être organisé au sein de l'unité de néonatologie" ] ;
     fhir:designation ( [
       fhir:language [ fhir:v "fr-FR" ] ;
       fhir:use [
         a sct:900000000000013009 ;
