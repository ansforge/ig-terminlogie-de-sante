     ]
  ], [
     fhir:index 301 ;
     fhir:CodeSystem.concept.code [ fhir:value "302" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Centre d’Accueil et de Crise (CAC)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Le centre d'accueil et de crise (CAC) est un dispositif d'accueil en continu répondant au besoin non programmé d'évaluation et d'orientation du patient relevant d'une situation clinique de crise. Le centre peut disposer de lits d'hospitalisation de très courte durée permettant d'initier la prise en charge thérapeutique du patient dans une perspective de relai vers un autre mode de prise en charge." ] ;
     fhir:CodeSystem.concept.designation [
