     fhir:CodeSystem.concept.display [ fhir:value "Soin diététique et nutritionnel des allergies alimentaires" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Adaptation de l’alimentation pour prévenir les réactions allergiques, garantir un bon état nutritionnel et une alimentation sûre, équilibrée et adaptée à leurs besoins spécifiques." ] ;
