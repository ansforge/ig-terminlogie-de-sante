     fhir:index 0 ;
     fhir:CodeSystem.concept.code [ fhir:value "AM" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Catégorie AM, permis cyclomoteur" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Cette catégorie (AM) permet de conduire dès 14 ans des cyclomoteurs (motocyclettes de moins de 50 cm3) et des voiturettes (quadricycles légers). Elle est délivrée à l’issue d’une formation d’une durée minimale de 8 heures. C’est la seule catégorie exclue du régime de permis à points." ] ;
