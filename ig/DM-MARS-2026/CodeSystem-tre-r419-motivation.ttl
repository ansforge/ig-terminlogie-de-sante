       ]
     ] )
  ] [
     fhir:code [ fhir:v "222" ] ;
     fhir:display [ fhir:v "Attrib ACTP" ] ;
     fhir:definition [ fhir:v "Vous êtes déjà bénéficiaire de l'ACTP. La CDAPH a reconnu que votre situation de handicap permet le renouvellement de l'ACTP (article 95 de la loi du 11 février 2005 et article L. 245-1 du code de l'action sociale et des familles dans sa rédaction antérieure à la loi du 11 février 2005)." ] ;
