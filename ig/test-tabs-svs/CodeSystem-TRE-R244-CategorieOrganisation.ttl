  ], [
     fhir:index 39 ;
     fhir:CodeSystem.concept.code [ fhir:value "40" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Maison d'accueil spécialisée (MAS)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Structure d'hébergement permanent et de soins pour adulte handicapé dépendant qui n'arrive pas à réaliser seul les actes de la vie courante (se nourrir, s'habiller...), elles proposent des activités quotidiennes d'éveil ou occupationnelles (musique, relaxation, activités manuelles…) et sont structurées autour d'unités de vie comprenant 8 à 10 chambres individuelles. Elles accueillent des personnes un peu plus dépendantes que la population hébergée en foyer d'accueil médicalisé (Fam)" ] ;
     fhir:CodeSystem.concept.designation [
