<https://interop.esante.gouv.fr/terminologies/CodeSystem/v3-EntityCode> a fhir:CodeSystem ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "v3-EntityCode"] ;
