       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 276 ;
     fhir:CodeSystem.concept.code [ fhir:value "277" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Equipe de coordination hospitalière de tissus et/ou d’organes" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Il s'agit d'une équipe hospitalière pluridisciplinaire chargée d’identifier les donneurs potentiels d’organes et de tissus, d’organiser et de coordonner les prélèvements, en garantissant le respect des règles légales, éthiques et de sécurité sanitaire, ainsi que l’accompagnement des proches. Elle assure la liaison entre les services hospitaliers, les équipes de greffe et l’Agence de la biomédecine pour la traçabilité et la qualité du don." ] ;
     fhir:CodeSystem.concept.designation [
