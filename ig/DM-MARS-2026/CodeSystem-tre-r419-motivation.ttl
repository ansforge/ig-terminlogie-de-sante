     fhir:code [ fhir:v "566" ] ;
     fhir:display [ fhir:v "Attrib EA milieu ordinaire avec difficultés" ] ;
     fhir:definition [ fhir:v "Vous êtes reconnu travailleur handicapé. Après évaluation de votre situation, de vos capacités et en tenant compte de vos besoins, la CDAPH a reconnu que vous rencontrez des difficultés particulières pour sécuriser de façon durable votre insertion professionnelle.  Par conséquent, vous pouvez bénéficier de l'offre d'une plateforme Emploi accompagné (EA) (articles L.5213-2-1 et D.5213-89 du code du travail)." ] ;
