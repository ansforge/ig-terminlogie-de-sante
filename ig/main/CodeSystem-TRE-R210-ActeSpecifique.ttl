     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1404 ;
     fhir:CodeSystem.concept.code [ fhir:value "1405" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Assistance respiratoire extracorporelle par ECMO" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Technique de circulation extracorporelle pouvant offrir une assistance cardiaque, respiratoire ou cardiorespiratoire selon les modalités techniques utilisées, elle comprend une pompe générant un débit et une membrane permettant à la fois d'éliminer le CO2 et d'enrichir le sang en oxygène." ] ;
