     fhir:CodeSystem.concept.display [ fhir:value "AffiliationRoleType" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Concepts characterizing the type of association formed by player and scoper when there is a recognized Affiliate role by which the two parties are related.\r\n\r\n*Examples:* Business Partner, Business Associate, Colleague" ] ;
