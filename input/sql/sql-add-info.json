{
  "name" : "ValueSetView",
  "resource" : "ValueSet",
  "select": [
    {
        "column": [
            { "name": "id","path": "id"},
            { "name": "name","path": "name"},
            { "name": "title", "path": "title"},
            { "name": "url", "path": "url"},
            { "name": "status", "path": "status"}
        ],
        "select": [
            {
                "forEach": "compose.include",
                "column": [ {  "path": "system", "name": "system" } ],
                "select": [{
                  "forEach": "concept",
                  "column": [
                      {"name": "code", "path": "code"},
                      {"name": "display", "path": "display"}
                      ]
                }]

            }

        ]
    }
],
  "where"  : [{
    "path" : "ValueSet.url.exists()"
  }]
}
