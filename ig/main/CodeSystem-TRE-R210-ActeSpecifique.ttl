     fhir:index 1515 ;
     fhir:CodeSystem.concept.code [ fhir:value "1517" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Parcours surpoids et obésité pédiatrique « Mission : Retrouve ton Cap »" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Acte de soin encadré dans les dispositifs régionaux type « Mission Retrouve ton Cap », assurant une prise en charge gratuite ou partiellement remboursée dans le cadre d'un parcours de soins de prise en charge de l'obésité" ] ;
