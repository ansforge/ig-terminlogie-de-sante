  fhir:CodeSystem.title [ fhir:value "Classification internationale des maladies et des problèmes de santé connexes - 10ème révision - Version française à usage PMSI (Programme Médicalisé des Systèmes d'Information)"] ;
  fhir:CodeSystem.status [ fhir:value "active"] ;
