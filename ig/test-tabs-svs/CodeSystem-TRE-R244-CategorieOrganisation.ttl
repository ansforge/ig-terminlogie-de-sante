     fhir:index 133 ;
     fhir:CodeSystem.concept.code [ fhir:value "134" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Maison des adolescents (MDA)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Structures ayant pour missions : l'accueil, l'information, la prévention et la promotion de la santé, l'accompagnement et la prise en charge multidisciplinaire (médecin, psychologue, juriste, infirmière ou infirmier, éducateur ou éducatrice, etc.) des adolescents et jeunes adultes, de leurs familles et des professionnels qui les entourent, pour répondre aux questions relatives à l'adolescence (sexualité, puberté, consommation de toxiques, santé mentale, etc.)" ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
