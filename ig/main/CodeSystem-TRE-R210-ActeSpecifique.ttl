       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1494 ;
     fhir:CodeSystem.concept.code [ fhir:value "1496" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement des troubles de l'écriture" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Consiste à évaluer, soutenir et développer les compétences graphomotrices des personnes en difficulté, afin de favoriser leur autonomie, leur inclusion scolaire, sociale et professionnelle. Cet accompagnement comprend la mise en place de stratégies compensatoires, l’adaptation de l’environnement et des outils (dont numériques), ainsi que des interventions de rééducation et de réadaptation personnalisées.Cette orientation est étayée par la réalisation de formations continues spécifiques auprès de cette population (appuyées de données probantes) et d’une expérience professionnelle" ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-07-23T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1495 ;
     fhir:CodeSystem.concept.code [ fhir:value "1497" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement ergothérapique à l'accès aux nouvelles technologies" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "L'accès à des nouvelles technologies, telles que l’impression 3D et/ou la robotique et/ou le gaming, nécessitent l’acquisition de compétences spécifiques en ergothérapie sur ces technologies en particulier, étayée par l’analyse ergothérapeutique spécifique : interaction personne-environnement-activité." ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-07-23T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1496 ;
     fhir:CodeSystem.concept.code [ fhir:value "1498" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement ergothérapique auprès des proches aidants (proches et professionnels) : apprentissage de techniques d’accompagnement" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Apprentissage de techniques d’accompagnement ergothérapique qui vise à améliorer la compréhension de l’impact de la pathologie dans le quotidien et à mettre en place des stratégies d’adaptation visant l’amélioration de la qualité de vie et la participation.  Cet accompagnement inclut l’évaluation des compétences, l’orientation professionnelle, la formation, l’adaptation des postes de travail et la coordination avec les acteurs médico-sociaux, afin de favoriser une intégration professionnelle durable et adaptée aux capacités de la personne.Cette orientation est étayée par la réalisation de formations continues spécifiques auprès de cette population (appuyées de données probantes) et d’une expérience professionnelle" ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
         a sct:900000000000013009 ;
         fhir:Coding.system [ fhir:value "http://snomed.info/sct" ] ;
         fhir:Coding.code [ fhir:value "900000000000013009" ]
       ] ;
       fhir:CodeSystem.concept.designation.value [ fhir:value "Accompagnement ergothérapique auprès des proches aidants" ]
     ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2026-05-05T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1497 ;
     fhir:CodeSystem.concept.code [ fhir:value "1499" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement ergothérapique dans le cadre de déficiences visuelles" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Intervention de l’ergothérapeute qui vise à optimiser l’autonomie et la participation des personnes atteintes de déficience visuelle. Cela inclut l’évaluation des capacités résiduelles, l’adaptation de l’environnement, l’apprentissage de stratégies compensatoires, et la préconisation d’aides techniques pour faciliter les activités quotidiennes, professionnelles et sociales en toute sécurité. Cette orientation est étayée par la réalisation de formations continues spécifiques auprès de cette population (appuyées de données probantes) et d’une expérience professionnelle" ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-07-23T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1498 ;
     fhir:CodeSystem.concept.code [ fhir:value "1500" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement ergothérapique dans le cadre de maladies neuro-évolutives (SLA, SEP, Parkinson, Alzheimer, PNM)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Accompagnement ergothérapeutique qui vise à maintenir l’autonomie et la qualité de vie des patients en adaptant leur environnement, en proposant des aides techniques et en compensant les déficits fonctionnels. Cet accompagnement inclut l’évaluation des compétences, l’orientation professionnelle, la formation, l’adaptation des postes de travail et la coordination avec les acteurs médico-sociaux, afin de favoriser une intégration professionnelle durable et adaptée aux capacités de la personne." ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
         a sct:900000000000013009 ;
         fhir:Coding.system [ fhir:value "http://snomed.info/sct" ] ;
         fhir:Coding.code [ fhir:value "900000000000013009" ]
       ] ;
       fhir:CodeSystem.concept.designation.value [ fhir:value "Accompagnement ergothérapique dans le cadre de maladies neuro-évolutives" ]
     ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2026-05-05T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1499 ;
     fhir:CodeSystem.concept.code [ fhir:value "1501" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement ergothérapique dans le cadre de particularités sensorielles (TND)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Intervention de l’ergothérapeute visant à évaluer, adapter et optimiser l’environnement et les activités des personnes présentant des troubles neurodéveloppementaux (TND) avec des particularités sensorielles (désigne une façon atypique de percevoir, traiter et réagir aux stimuli sensoriels (bruits, lumières, textures, odeurs, mouvements, etc.).)  Cet accompagnement vise à favoriser l’autonomie, la participation sociale et le bien-être en proposant des stratégies de compensation, des aménagements spécifiques et un travail sur la régulation sensorielle. Cette orientation est étayée par la réalisation de formations continues spécifiques auprès de cette population (appuyées de données probantes) et d’une expérience professionnelle" ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-07-23T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1500 ;
     fhir:CodeSystem.concept.code [ fhir:value "1502" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement ergothérapique dans le cadre de pathologies neurologiques (AVC, TCE)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Intervention de l’ergothérapeute visant à restaurer l’autonomie et la qualité de vie des patients atteints d’affections neurologiques (AVC, traumatisme crânien). Il évalue les déficits moteurs, cognitifs et sensoriels, met en place des stratégies de compensation, adapte l’environnement et préconise des aides techniques pour optimiser la réadaptation et la réinsertion sociale et professionnelle.Cette orientation est étayée par la réalisation de formations continues spécifiques auprès de cette population (appuyées de données probantes) et d’une expérience professionnelle" ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
