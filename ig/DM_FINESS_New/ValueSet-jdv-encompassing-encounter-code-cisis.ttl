  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "jdv-encompassing-encounter-code-cisis"] ; # 
  fhir:meta [
     fhir:versionId [ fhir:v "6" ] ;
     fhir:lastUpdated [ fhir:v "2025-12-17T15:43:52.296+01:00"^^xsd:dateTime ] ;
     fhir:profile ( [
       fhir:v "http://hl7.org/fhir/StructureDefinition/shareablevalueset"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/shareablevalueset>
