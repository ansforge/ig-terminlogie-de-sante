       ]
     ] [
       fhir:code [ fhir:v "status" ] ;
       fhir:value [
         a fhir:Code ;
         fhir:v "active"
       ]
     ] )
  ] [
     fhir:code [ fhir:v "507" ] ;
     fhir:display [ fhir:v "Attrib PCH Parentalité AH Monoparentalité" ] ;
     fhir:definition [ fhir:v "Après évaluation de votre situation, de votre autonomie et en tenant compte de vos besoins, la CDAPH a reconnu que vous avez des difficultés pour réaliser des actes relatifs à l'exercice de la parentalité et que vous avez besoin d'aide pour réaliser ces actes.  Ces difficultés et l'âge de votre (vos) enfant(s) vous permettent de remplir les critères pour l'accès au forfait parentalité au titre de l'aide humaine de la prestation de compensation du handicap.  De plus votre situation de monoparentalité entraîne une majoration de 50% de ce forfait (annexe 2-5 et article L.245-3 du code de l'action sociale et des familles)" ] ;
