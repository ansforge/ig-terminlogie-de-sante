  ], [
     fhir:index 275 ;
     fhir:CodeSystem.concept.code [ fhir:value "276" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Unité d’Accueil et de Soins pour personnes Sourdes et malentendantes (UASS)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Une Unité d'Accueil et de Soins pour patients Sourds (UASS) est une unité dédiée à l’accueil et à la prise en charge des personnes sourdes et malentendantes. Elle garantit un accès équitable aux soins grâce à des équipes formées, bilingues en français et en langue des signes française (LSF), capables d’adapter la communication pour accompagner au mieux les patients tout au long de leur parcours de soins. L'unité a pour objectif d'accueillir en consultation les patients sourds, malentendants, de les accompagner dans leur démarche de soins grâce à des interprètes et à des intermédiateurs. Elle propose sur rendez-vous des consultations de médecine générale (systématique), de psychologues (parfois) et des temps avec des assistantes sociales. Elle propose également l’accessibilité en langue des signes à toutes les activités (consultations de spécialistes, urgence, etc..) de l’établissement. Certaines unités sont spécifiques à la prise en charge en psychiatrie." ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
         a sct:900000000000013009 ;
         fhir:Coding.system [ fhir:value "http://snomed.info/sct" ] ;
         fhir:Coding.code [ fhir:value "900000000000013009" ]
       ] ;
       fhir:CodeSystem.concept.designation.value [ fhir:value "UASS" ]
     ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
