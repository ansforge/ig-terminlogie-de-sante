       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1505 ;
     fhir:CodeSystem.concept.code [ fhir:value "1507" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Programme de prévention primaire ergothérapique « Bien vieillir » (TaPasS)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Initiative visant à optimiser la participation sociale et la qualité de vie des personnes âgées vivant à domicile. Inspiré du modèle américain Lifestyle Redesign®, ce programme propose des activités significatives et des stratégies pour surmonter les obstacles liés au vieillissement. Il est coordonné par des ergothérapeutes et se déroule sur une période de 6 à 9 mois, avec des séances de groupe hebdomadaires et des séances individuelles mensuelles" ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-07-23T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1506 ;
     fhir:CodeSystem.concept.code [ fhir:value "1508" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement ergothérapique en milieu scolaire" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Interventions adaptées aux élèves en situation de handicap pour améliorer leur participation aux activités scolaires et leur autonomie. Les ergothérapeutes évaluent les besoins des élèves, proposent des aménagements de l'environnement scolaire et des stratégies pour faciliter l'apprentissage.Cette orientation est étayée par la réalisation de formations continues spécifiques auprès de cette population (appuyées de données probantes) et d’une expérience professionnelle" ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-07-23T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1507 ;
     fhir:CodeSystem.concept.code [ fhir:value "1509" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Accompagnement ergothérapique en réhabilitation psycho-sociale" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Consiste à mettre en œuvre des interventions visant à améliorer l'autonomie, l'intégration sociale et la qualité de vie des personnes ayant des troubles psychiques. Les ergothérapeutes évaluent les capacités et les besoins des patients, et proposent des activités thérapeutiques adaptées pour favoriser leur réinsertion sociale et professionnelle. Cette orientation est étayée par la réalisation de formations continues spécifiques auprès de cette population (appuyées de données probantes) et d’une expérience professionnelle" ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-03-28T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 1 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateMaj" ] ;
       fhir:CodeSystem.concept.property.valueDateTime [ fhir:value "2025-07-23T12:00:00+01:00"^^xsd:dateTime ]
     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1508 ;
     fhir:CodeSystem.concept.code [ fhir:value "1510" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Evaluation et accompagnement ergothérapique au positionnement au fauteuil roulant (MCPAA) et positionnement au lit" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Consiste à analyser et ajuster la posture des personnes en situation de handicap pour prévenir les complications liées à une mauvaise position. Cela inclut l'utilisation de fauteuils roulants adaptés et de dispositifs de positionnement au lit pour assurer confort, sécurité et autonomie. Cette démarche est réalisée par des ergothérapeutes et est encadrée par des recommandations professionnelles. Le positionnement au fauteuil roulant au travers de la MCPAA nécessite l’acquisition de compétences spécifiques en ergothérapie par des formations complémentaires, cela est également valable concernant le positionnement au lit à visée préventive (douleurs, inconfort, risque de déformation, risques d’escarres)" ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
       fhir:CodeSystem.concept.designation.language [ fhir:value "fr-FR" ] ;
       fhir:CodeSystem.concept.designation.use [
