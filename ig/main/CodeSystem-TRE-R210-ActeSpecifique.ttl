     ], [
       fhir:index 2 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "status" ] ;
       fhir:CodeSystem.concept.property.valueCode [ fhir:value "active" ]
     ]
  ], [
     fhir:index 1530 ;
     fhir:CodeSystem.concept.code [ fhir:value "1532" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Surveillance d'ictère néonatal par mesure transcutanée" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Méthode non invasive effectuée en maternité (sur le front ou le sternum) qui permet d’estimer la bilirubine cutanée à l’aide d’un bilirubinomètre transcutané, afin de détecter précocement un ictère nécessitant un dosage sanguin confirmant le diagnostic" ] ;
