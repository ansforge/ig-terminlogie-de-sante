       ], [
         fhir:index 14 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "HX" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Hors seuil supérieur" ]
       ], [
         fhir:index 15 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "I" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Intermédiaire" ]
       ], [
         fhir:index 16 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "IE" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Preuves insuffisantes" ]
       ], [
         fhir:index 17 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "IND" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Indéterminé" ]
       ], [
         fhir:index 18 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "L" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Anormalement bas" ]
       ], [
         fhir:index 19 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "LL" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Très anormalement bas, alerte" ]
       ], [
         fhir:index 20 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "LU" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Significativement bas" ]
       ], [
         fhir:index 21 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "LX" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Hors seuil inférieur" ]
       ], [
         fhir:index 22 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "N" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Normal" ]
       ], [
         fhir:index 23 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "NCL" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Pas de standard défini" ]
       ], [
         fhir:index 24 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "ND" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Non détecté" ]
       ], [
         fhir:index 25 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "NEG" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Négatif" ]
       ], [
         fhir:index 26 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "NR" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Non réactif" ]
