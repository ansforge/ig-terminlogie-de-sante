     ]
  ], [
     fhir:index 1512 ;
     fhir:CodeSystem.concept.code [ fhir:value "1514" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Dialyse longue nocturne" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Modalité d’hémodialyse réalisée en centre, pendant le sommeil, proposée sur la base du volontariat du patient, avec branchement et surveillance réalisés par du personnel soignant de nuit . Cette organisation permet une épuration plus douce et efficace, améliore la tolérance cardiovasculaire, le contrôle tensionnel, l’équilibre métabolique et facilite le maintien d’une activité socio-professionnelle." ] ;
