       fhir:value [
         a fhir:Code ;
         fhir:v "active"
       ]
     ] )
  ] [
     fhir:code [ fhir:v "301" ] ;
     fhir:display [ fhir:v "Rejet PCH enfant Durée difficultés moins 1an" ] ;
     fhir:definition [ fhir:v "Après évaluation de la situation de votre enfant, de son autonomie et en tenant compte de ses besoins, la CDAPH a reconnu qu'il a des difficultés pour réaliser des activités de la vie quotidienne (annexe 2-5 du code de l'action sociale et des familles). Toutefois, la CDAPH a reconnu que ces difficultés ne sont pas durables. Votre enfant ne peut donc pas bénéficier de la PCH (article L.114 du code de l'action sociale et des familles)." ] ;
