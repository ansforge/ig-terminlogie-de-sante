       fhir:ValueSet.compose.include.system [ fhir:value "http://terminology.hl7.org/CodeSystem/v3-ObservationInterpretation" ] ;
       fhir:ValueSet.compose.include.version [ fhir:value "4.0.0" ] ;
       fhir:ValueSet.compose.include.concept [
         fhir:index 0 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "<" ] ;
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Inférieur à la limite de détection" ]
       ], [
         fhir:index 1 ;
         fhir:ValueSet.compose.include.concept.code [ fhir:value ">" ] ;
