  ], [
     fhir:index 809 ;
     fhir:CodeSystem.concept.code [ fhir:value "0810" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Séance de préparation à la naissance et à la parentalité en groupe" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Accompagnement global de la femme et du couple en favorisant leur participation active dans le projet de naissance, par une approche éducative et préventive, en développant les connaissances et les aptitudes nécessaires sur les modalités d'accouchement, les possibilités de suivi pendant la période postnatale, y compris les conditions d'un retour précoce à domicile, le recours en cas de difficultés, les soins essentiels ainsi que les pratiques parentales à l'égard de l'enfant à élever. La préparation à la naissance et à la parentalité complète le suivi médical." ] ;
     fhir:CodeSystem.concept.property [
