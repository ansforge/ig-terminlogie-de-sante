     ]
  ], [
     fhir:index 1531 ;
     fhir:CodeSystem.concept.code [ fhir:value "1533" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Test de Guthrie hors établissement (test néonatal du buvard)" ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
