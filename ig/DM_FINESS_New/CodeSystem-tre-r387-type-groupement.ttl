  fhir:concept ( [
     fhir:code [ fhir:v "01" ] ;
     fhir:display [ fhir:v "Groupement de coopération conventionnelle" ] ;
     fhir:definition [ fhir:v "La coopération conventionnelle ne donne pas lieu à la création d'une structure juridique.  Elle n'est matérialisée que par un engagement qui associe l'ensemble des membres du groupe. Une des personnes morales appartenant au groupe sera dite 'PM support'. Elle a un rôle particulier au sein du groupe notamment pour les échanges avec l'extérieur." ] ;
     fhir:designation ( [
       fhir:language [ fhir:v "fr-FR" ] ;
       fhir:use [
