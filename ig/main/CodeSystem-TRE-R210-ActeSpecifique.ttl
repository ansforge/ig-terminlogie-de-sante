     fhir:index 1525 ;
     fhir:CodeSystem.concept.code [ fhir:value "1527" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Soin diététique et nutritionnel pour la gestion des troubles hormonaux (hypothyroïdie, SOPK, endométriose)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Suivi personnalisé visant à améliorer les symptômes, limiter les complications métaboliques, contribuer à l’équilibre hormonal et à la réduction des symptômes associés. et accompagner le vécu des patientes." ] ;
