# - resource -------------------------------------------------------------------

<https://interop.esante.gouv.fr/terminologies/ValueSet/jdv-hl7-v3-PersonalRelationshipRoleType-cisis> a fhir:ValueSet ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "jdv-hl7-v3-PersonalRelationshipRoleType-cisis"] ;
  fhir:Resource.meta [
     fhir:Meta.versionId [ fhir:value "10" ] ;
     fhir:Meta.lastUpdated [ fhir:value "2026-06-22T14:01:15.532+02:00"^^xsd:dateTime ] ;
     fhir:Meta.profile [
       fhir:value "http://hl7.org/fhir/StructureDefinition/shareablevalueset" ;
