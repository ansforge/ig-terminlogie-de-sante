  ], [
     fhir:index 1398 ;
     fhir:CodeSystem.concept.code [ fhir:value "1399" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Unité de réanimation pédiatrique de recours" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Structures spécialisées, désignées dans le cadre de la réforme des autorisations de soins critiques, qui assurent la prise en charge des enfants nécessitant des soins intensifs et une expertise pédiatrique avancée, que ne peuvent offrir les autres structures de soins critiques. Elles sont dédiées aux situations les plus complexes et graves, impliquant des défaillances vitales, souvent multiples, qui nécessitent des techniques de réanimation spécialisées et des compétences multidisciplinaires." ] ;
