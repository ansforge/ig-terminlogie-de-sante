     fhir:CodeSystem.concept.definition [ fhir:value "The subject is currently experiencing the condition or situation, there is evidence of the condition or situation, or considered to be a significant risk." ] ;
     fhir:CodeSystem.concept.concept [
       fhir:index 0 ;
       fhir:CodeSystem.concept.code [ fhir:value "recurrence" ] ;
       fhir:CodeSystem.concept.display [ fhir:value "Recurrence" ] ;
       fhir:CodeSystem.concept.definition [ fhir:value "The subject is experiencing a reoccurence or repeating of a previously resolved condition or situation, e.g. urinary tract infection, food insecurity." ]
     ], [
