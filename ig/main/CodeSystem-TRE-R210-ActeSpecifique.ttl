         fhir:Coding.code [ fhir:value "900000000000013009" ]
       ] ;
       fhir:CodeSystem.concept.designation.value [ fhir:value "Eval et accomp à la mise en place de communication augmentative-alternative" ]
     ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
