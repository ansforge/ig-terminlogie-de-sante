     fhir:status [ fhir:v "extensions" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Narratif généré : EnsembleValeurs jdv-tumeur-cisis</b></p><a name=\"jdv-tumeur-cisis\"> </a><a name=\"hcjdv-tumeur-cisis\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\">version : 6; Dernière mise à jour : 2026-02-23 15:00:08+0100</p><p style=\"margin-bottom: 0px\">Profil: <a href=\"http://hl7.org/fhir/R4/shareablevalueset.html\">Shareable ValueSet</a></p></div><ul><li>Include ce(s) code(s) tel qu'il(s) est (sont) défini(s) dans <a href=\"http://tx.fhir.org/r4\"><code>http://hl7.org/fhir/sid/icd-10</code></a><span style=\"opacity: 0.5\" title=\"La version n'est pas explicitement indiquée. Lors de la génération de cette spécification, la version la plus récente 2019-covid-expanded a été utilisée\"> version ⏿2019-covid-expanded</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Affichage</b></td><td><b>Définition</b></td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-B21\">B21</a></td><td>Immunodéficience humaine virale [VIH], à l'origine de tumeurs malignes</td><td>Human immunodeficiency virus [HIV] disease resulting in malignant neoplasms</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-B21.460\">B21.0</a></td><td>Maladie par VIH à l'origine d'un sarcome de Kaposi</td><td>HIV disease resulting in Kaposi sarcoma</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-B21.461\">B21.1</a></td><td>Maladie par VIH à l'origine d'un lymphome de Burkitt</td><td>HIV disease resulting in Burkitt lymphoma</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-B21.462\">B21.2</a></td><td>Maladie par VIH à l'origine d'autres lymphomes non hodgkiniens</td><td>HIV disease resulting in other types of non-Hodgkin lymphoma</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-B21.463\">B21.3</a></td><td>Maladie par VIH à l'origine d'autres tumeurs malignes des tissus lymphoïde, hématopoïétique et apparentés</td><td>HIV disease resulting in other malignant neoplasms of lymphoid, haematopoietic and related tissue</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-B21.467\">B21.7</a></td><td>Maladie par VIH à l'origine de tumeurs malignes multiples</td><td>HIV disease resulting in multiple malignant neoplasms</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-B21.468\">B21.8</a></td><td>Maladie par VIH à l'origine d'autres tumeurs malignes</td><td>HIV disease resulting in other malignant neoplasms</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-B21.469\">B21.9</a></td><td>Maladie par VIH à l'origine d'une tumeur maligne, sans précision</td><td>HIV disease resulting in unspecified malignant neoplasm</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-C00\">C00</a></td><td>Tumeur maligne de la lèvre</td><td>Malignant neoplasm of lip</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-C00.460\">C00.0</a></td><td>Tumeur maligne de la lèvre supérieure, bord libre</td><td>External upper lip</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-C00.461\">C00.1</a></td><td>Tumeur maligne de la lèvre supérieure, bord libre</td><td>External lower lip</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-C00.462\">C00.2</a></td><td>Tumeur maligne de la lèvre, sans précision, bord libre</td><td>External lip, unspecified</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-C00.463\">C00.3</a></td><td>Tumeur maligne de la lèvre supérieure, face interne</td><td>Upper lip, inner aspect</td></tr><tr><td><a href=\"http://tx.fhir.org/r4/ValueSet/1846#1846-C00.464\">C00.4</a></td><td>Tumeur maligne de la lèvre inférieure, face interne</td><td>Lower lip, inner aspect</td></tr><tr><td><a href=