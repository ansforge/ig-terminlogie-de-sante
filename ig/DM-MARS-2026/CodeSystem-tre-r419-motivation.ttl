     fhir:code [ fhir:v "564" ] ;
     fhir:display [ fhir:v "Attrib EA ESAT avec projet milieu ordinaire" ] ;
     fhir:definition [ fhir:v "Vous êtes accueilli dans un établissement ou service d'accompagnement par le travail (ESAT). La CDAPH a reconnu que vous avez un projet d'insertion en milieu ordinaire de travail. Par conséquent, vous pouvez bénéficier de l'offre d'une plateforme Emploi accompagné (EA) (articles L.5213-2-1 et D.5213-89 du code du travail)." ] ;
