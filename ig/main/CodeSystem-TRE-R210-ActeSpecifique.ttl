  ], [
     fhir:index 1403 ;
     fhir:CodeSystem.concept.code [ fhir:value "1404" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Assistance circulatoire extracorporelle par ECMO" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Pompe permettant d'assurer des débits sanguins extracorporels au travers d'un oxygénateur assurant les échanges gazeux. C'est une technique dérivée de la circulation extracorporelle, le sang est prélevé et renvoyé au patient à l'aide de canules vasculaires de très gros calibre, positionnées sur des axes vasculaires majeurs (fémorales, jugulaires)." ] ;
     fhir:CodeSystem.concept.property [
       fhir:index 0 ;
       fhir:CodeSystem.concept.property.code [ fhir:value "dateValid" ] ;
