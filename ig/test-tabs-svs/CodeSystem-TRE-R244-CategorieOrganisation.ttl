  ], [
     fhir:index 280 ;
     fhir:CodeSystem.concept.code [ fhir:value "281" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Centre Médico-Psychologique Enfant et Adolescent (CMPEA)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Il s'agit d'un service de santé mentale destiné aux enfants et adolescents qui propose des consultations, évaluations et suivis psychologiques ou psychiatriques, en lien avec la famille et l’école." ] ;
