  ], [
     fhir:index 3 ;
     fhir:CodeSystem.concept.code [ fhir:value "SI01" ] ;
     fhir:CodeSystem.concept.display [ fhir:value "Exercice infirmier en pratique avancée pathologies chroniques stabilisées (SI)" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "Exercice infirmier autorisé en pratique avancée pour les pathologies chroniques stabilisées.  La notion de spécialité ordinale a été introduite sachant qu'il est nécessaire de distinguer l'exercice d'IPA de celui d'infirmier et que le diplôme ne suffit  pas pour autoriser l'exercice d'IPA. Il faut 3 ans de pratique infirmière pour pouvoir exercer comme IPA; mais le cursus d'IPA peut être accessible dans le prolongement du DE d'infirmier.  Un IPA peut exercer des activités d'IPA dans plusieurs spécialités, mais aussi, plus fréquemment cumuler des activités d'IPA et d'activité d'infirmier polyvalent du niveau du DE Infirmier." ] ;
     fhir:CodeSystem.concept.designation [
       fhir:index 0 ;
